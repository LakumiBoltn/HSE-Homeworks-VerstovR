def middle_letters(word):
    length = len(word)
    if length == 0:
        return ""

    middle = length // 2
    return word[middle] if length % 2 == 1 else word[middle - 1:middle + 1]

test_cases = ['test', 'testing', 'a', 'ab', 'hello']
for word in test_cases:
    result = middle_letters(word)
    print(f"word = '{word}' Результат: '{result}'")
